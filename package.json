{
  "name": "zero-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync:template": "node scripts/sync-template.mjs",
    "verify:template-sync": "node scripts/verify-template-sync.mjs",
    "verify:pack": "node scripts/verify-pack-contents.mjs",
    "smoke:tarball": "node scripts/smoke-pack-install.mjs",
    "release:check": "npm run verify:template-sync && npm run check && npm run build && npm run verify:pack && npm run smoke:tarball",
    "build": "npm run build -w create-zero-ts",
    "typecheck": "npm run typecheck -w create-zero-ts",
    "lint": "npm run lint -w create-zero-ts",
    "test": "npm run test -w create-zero-ts",
    "check": "npm run check -w create-zero-ts"
  }
}
