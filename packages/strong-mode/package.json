{
  "name": "strong-mode",
  "version": "0.2.1",
  "description": "A CLI that makes TypeScript vibe coding safer with strict defaults and quality guardrails.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ranteck/strong-mode.git",
    "directory": "packages/strong-mode"
  },
  "homepage": "https://github.com/Ranteck/strong-mode#readme",
  "keywords": [
    "typescript",
    "eslint",
    "strict",
    "guardrails",
    "quality",
    "vibe-coding",
    "ai-assisted-coding",
    "strong-mode",
    "code-quality"
  ],
  "type": "module",
  "bin": {
    "strong-mode": "dist/cli.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prebuild": "node ../../scripts/sync-template.mjs",
    "build": "tsup --config tsup.config.ts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepack": "node ../../scripts/sync-template.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "cross-spawn": "^7.0.6",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
