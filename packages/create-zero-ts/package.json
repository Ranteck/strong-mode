{
  "name": "create-zero-ts",
  "version": "0.1.0",
  "description": "Ultra-strict TypeScript project generator",
  "type": "module",
  "bin": {
    "create-zero-ts": "dist/cli.js",
    "zero-ts": "dist/cli.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "sync:template": "node ../../scripts/sync-template.mjs",
    "verify:template-sync": "node ../../scripts/verify-template-sync.mjs",
    "verify:pack": "node ../../scripts/verify-pack-contents.mjs",
    "smoke:tarball": "node ../../scripts/smoke-pack-install.mjs",
    "build": "tsup --config tsup.config.ts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run verify:template-sync && npm run check && npm run build && npm run verify:pack && npm run smoke:tarball"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "cross-spawn": "^7.0.6",
    "picocolors": "^1.1.1",
    "validate-npm-package-name": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.13.10",
    "@types/validate-npm-package-name": "^4.0.2",
    "eslint": "^9.22.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
