{
  "name": "__PROJECT_NAME__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --noEmit && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dead-code": "knip",
    "deps:graph": "depcruise src --config depcruise.config.cjs --output-type err-long",
    "deps:cycles": "madge src --circular --extensions ts",
    "audit": "npm audit --audit-level=high",
    "zero:check": "npm run typecheck && npm run lint && npm run format:check && npm run dead-code",
    "zero:quality": "npm run zero:check && npm run test:coverage && npm run deps:graph && npm run deps:cycles && npm run audit",
    "check": "npm run zero:check",
    "quality": "npm run zero:quality",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^10.0.2",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "knip": "^5.85.0",
    "lefthook": "^2.1.1",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
