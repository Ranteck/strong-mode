{
  "name": "__PROJECT_NAME__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --noEmit && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dead-code": "knip",
    "deps:graph": "depcruise src --config depcruise.config.cjs --output-type err-long",
    "deps:cycles": "madge src --circular --extensions ts",
    "audit": "npm audit --audit-level=high",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run dead-code",
    "quality": "npm run check && npm run test:coverage && npm run deps:graph && npm run deps:cycles && npm run audit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.22.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-perfectionist": "^4.10.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "knip": "^5.45.0",
    "lefthook": "^1.11.2",
    "madge": "^8.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
